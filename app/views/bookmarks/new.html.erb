<h1>New Bookmark</h1>

<form action="/bookmarks" method="post">
  <p>
    <label for="url">URL</label><br>
    <input id="url" name="url" type="text" placeholder="https://example.com" autofocus>
  </p>
  <p>
    <label for="title">Title <small>(optional)</small></label><br>
    <input id="title" name="title" type="text" placeholder="Short label">
  </p>
  <p>
    <button type="submit">Create bookmark</button>
    &middot;
    <a href="/bookmarks">Cancel</a>
  </p>
</form>
