<!doctype html>
<html>
  <head>
    <meta charset="utf-8">
    <title>Spinel App</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;700&display=swap" rel="stylesheet">
    <script>
      // Pre-paint so the page doesn't flash light before JS runs. If
      // the user has no stored preference we seed from the OS, then
      // persist so subsequent visits skip the matchMedia probe.
      (function () {
        var t = localStorage.getItem("theme");
        if (!t) {
          t = (window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches) ? "dark" : "light";
          localStorage.setItem("theme", t);
        }
        document.documentElement.setAttribute("data-theme", t);
      })();
    </script>
    <style>
      :root {
        --bg: #fff; --fg: #222; --muted: #888;
        --border: #eee; --code-bg: #f7f7f7;
        --accent: #0066cc;
      }
      :root[data-theme="dark"] {
        --bg: #141414; --fg: #e8e8e8; --muted: #9a9a9a;
        --border: #2a2a2a; --code-bg: #1f1f1f;
        --accent: #6ab0ff;
      }
      body {
        font-family: 'IBM Plex Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
        max-width: 48rem;
        margin: 0 auto;
        padding: 1.5rem;
        background: var(--bg);
        color: var(--fg);
        transition: background 0.15s, color 0.15s;
      }
      header nav { display: flex; flex-wrap: wrap; gap: 0.5rem 1rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border); }
      header nav a { color: var(--accent); text-decoration: none; }
      header nav a:hover { text-decoration: underline; }
      main { padding: 1.5rem 0; }
      main a { color: var(--accent); }
      code { background: var(--code-bg); padding: 0.1rem 0.3rem; border-radius: 3px; }
      footer { color: var(--muted); font-size: 0.85rem; border-top: 1px solid var(--border); padding-top: 1rem; }
      #theme-toggle {
        position: fixed; top: 1rem; right: 1rem;
        background: transparent; border: 1px solid var(--border);
        color: var(--fg); border-radius: 6px;
        padding: 0.4rem; cursor: pointer;
        display: inline-flex; align-items: center; justify-content: center;
      }
      #theme-toggle:hover { background: var(--code-bg); }
      #theme-toggle svg { width: 18px; height: 18px; display: none; }
      :root[data-theme="light"] #theme-toggle .icon-moon { display: inline-block; }
      :root[data-theme="dark"]  #theme-toggle .icon-sun  { display: inline-block; }
      .flash {
        position: fixed; top: 1rem; left: 50%; transform: translateX(-50%);
        max-width: 32rem; padding: 0.6rem 1rem; border-radius: 6px;
        border: 1px solid var(--border); background: var(--code-bg);
        color: var(--fg); font-size: 0.9rem; z-index: 10;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
      }
      .flash--notice { border-color: var(--accent); }
      .flash--error  { border-color: #d24; }
      .flash button {
        background: transparent; border: 0; color: var(--muted);
        margin-left: 0.5rem; cursor: pointer; font-size: 1rem;
      }
    </style>
  </head>
  <body>
    <button id="theme-toggle" aria-label="Toggle color theme" title="Toggle color theme">
      <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
      <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
    </button>

    <% if flash.has?("notice") %>
      <div class="flash flash--notice" role="status">
        <%= flash.get("notice") %>
        <button type="button" onclick="this.parentElement.remove()" aria-label="Dismiss">&times;</button>
      </div>
    <% end %>
    <% if flash.has?("error") %>
      <div class="flash flash--error" role="alert">
        <%= flash.get("error") %>
        <button type="button" onclick="this.parentElement.remove()" aria-label="Dismiss">&times;</button>
      </div>
    <% end %>

  <%= render(partial: "shared/navigation", locals: {}) %>

    <header><nav><a href="/">home</a> &middot; <a href="/about">about</a> &middot; <a href="/4regfreagaeg">404!</a> &middot; <a href="/crash">crash!</a> &middot; <a href="/users">users</a> &middot; <a href="/users/1">user 1</a> &middot; <a href="/users/42">user 42</a> &middot; <a href="/bookmarks">bookmarks</a> &middot; <a href="/filters">filters</a></nav></header>
    <main>
      <%= yield %>
    </main>
    <footer><small>Powered by Spinel + Fresco.</small></footer>

    <script>
      (function () {
        document.getElementById("theme-toggle").addEventListener("click", function () {
          var cur = document.documentElement.getAttribute("data-theme");
          var nxt = cur === "dark" ? "light" : "dark";
          document.documentElement.setAttribute("data-theme", nxt);
          localStorage.setItem("theme", nxt);
        });
      })();
    </script>
  </body>
</html>
